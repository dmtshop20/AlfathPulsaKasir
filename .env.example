# Database URLs from Supabase
# Use Transaction Mode (Port 6543) for DATABASE_URL
DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Use Session Mode (Port 5432) for DIRECT_URL
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxx.supabase.co:5432/postgres

# JWT Secret for Auth
JWT_SECRET=your_super_secret_jwt_key

# Node Environment
NODE_ENV=development
PORT=3000
